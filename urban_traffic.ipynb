import pandas as pd
import numpy as np

df = pd.read_csv("traffic.csv")

# Convert datetime
df["pickup_datetime"] = pd.to_datetime(df["pickup_datetime"])
df["dropoff_datetime"] = pd.to_datetime(df["dropoff_datetime"])

# Feature engineering
df["pickup_hour"] = df["pickup_datetime"].dt.hour
df["pickup_day"] = df["pickup_datetime"].dt.day_name()
df["trip_duration_min"] = df["trip_duration"] / 60

# Remove extreme values
df = df[(df["trip_duration_min"] > 1) & (df["trip_duration_min"] < 120)]

# Distance calculation (km approximation)
df["distance_km"] = (
    ((df["pickup_longitude"] - df["dropoff_longitude"]) * 111)**2 +
    ((df["pickup_latitude"] - df["dropoff_latitude"]) * 111)**2
) ** 0.5

df["distance_km"] = df["distance_km"].round(2)

# Peak hour
print(df.groupby("pickup_hour")["trip_duration_min"].mean())

# Trips per hour
print(df["pickup_hour"].value_counts().sort_index())

# Save cleaned dataset
df.to_csv("traffic_cleaned.csv", index=False)
